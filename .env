PORT=3000

# MongoDB Configuration - Local Development
MONGODB_URI=mongodb://127.0.0.1:27017/prescripto

# JWT Secret - Generate a strong random string in production
JWT_SECRET_KEY=prescripto_dev_secret_key_change_in_production

# CORS Configuration - Support multiple frontend apps on different ports
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Razorpay Payment Gateway - Use test keys for development
# Get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_1234567890
RAZORPAY_KEY_SECRET=test_secret_1234567890

CURRENCY=INR

# Cloudinary Configuration - Get from https://cloudinary.com
# For development, you can use placeholder or add your own
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=123456789
CLOUDINARY_SECRET_KEY=test_secret

# Email Configuration - Use Gmail App Password
EMAIL_SERVICE=gmail
EMAIL_NAME=prescript@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=prescript@gmail.com